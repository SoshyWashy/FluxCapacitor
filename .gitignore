```gitignore
# ==============================
# Fusion 360
# ==============================

# Fusion 360 temporary and recovery files
*.f3d~
*.f3z~
*.tmp
*.temp
*.bak
*.autosave
*.lock
*.lck

# Exported CAD and manufacturing files
*.stl
*.3mf
*.obj
*.step
*.stp
*.iges
*.igs
*.sat
*.dxf
*.gcode
*.nc
*.tap

# Rendered images and videos
renders/
render/
*.mp4
*.mov


# ==============================
# KiCad
# https://www.kicad.org/
# File format documentation:
# https://kicad.org/help/file-formats/
# ==============================

# Temporary and backup files
*.000
*.bak
*.bck
*.kicad_pcb-bak
*.kicad_sch-bak
*-backups
*.kicad_prl
*.sch-bak
*~
_autosave-*
*.tmp
*-save.pro
*-save.kicad_pcb
fp-info-cache
~*.lck
\#auto_saved_files#

# Netlist files exported from Eeschema
*.net

# Autorouter files exported from Pcbnew
*.dsn
*.ses

# Exported BOM files
*.xml
*.csv


# ==============================
# Operating system files
# ==============================

.DS_Store
Thumbs.db
desktop.ini


# ==============================
# Editor files
# ==============================

.vscode/
.idea/
*.swp
*.swo
```
